{
  "name": "habitat",
  "version": "0.1.0",
  "description": "Habitat command-line app.",
  "type": "module",
  "bin": {
    "habitat": "./src/index.ts"
  },
  "scripts": {
    "habitat": "bun run src/index.ts",
    "server": "bun run src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "web:dev": "bun run --cwd web dev",
    "web:build": "bun run --cwd web build",
    "web:typecheck": "bun run --cwd web typecheck"
  },
  "dependencies": {
    "commander": "^14",
    "hono": "^4.12.29"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.6.3"
  }
}
